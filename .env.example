# ==============================================================================
# Grievance Redressal System — Environment Variables
# Copy this file to '.env' and fill in your credentials.
# ==============================================================================

# ------------------------------------------------------------------------------
# REQUIRED — Application will NOT start without these
# ------------------------------------------------------------------------------

# MongoDB connection URL.
# Local:  mongodb://localhost:27017
# Atlas:  mongodb+srv://user:pass@cluster.mongodb.net/grievance_db
MONGODB_URL=mongodb://localhost:27017

# Database name
DATABASE_NAME=grievance_db

# Secret key for JWT signing.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32

# Groq API key for LLM inference and Whisper transcription.
# Obtain at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# ------------------------------------------------------------------------------
# OPTIONAL — Have sensible defaults
# ------------------------------------------------------------------------------

# LLM provider: groq (recommended), ollama, huggingface
LLM_PROVIDER=groq

# Groq model name
GROQ_MODEL=llama-3.3-70b-versatile

# Server configuration (Railway overrides PORT automatically)
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# API base URL — set this to your deployed backend's public URL for the frontend
# Local:   http://localhost:8000/api/v1
# Railway: https://your-backend-service.up.railway.app/api/v1
API_BASE_URL=http://localhost:8000/api/v1

# JWT settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200
REFRESH_TOKEN_EXPIRE_MINUTES=10080