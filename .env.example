# ============================================
# MongoDB Configuration
# ============================================
# Get free MongoDB Atlas cluster at: https://www.mongodb.com/cloud/atlas
# Connection string format: mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URL=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/grievance_db?retryWrites=true&w=majority
DATABASE_NAME=grievance_db

# ============================================
# LLM Provider Configuration
# ============================================
# Options: groq, ollama, huggingface
LLM_PROVIDER=groq

# --------------------------------------------
# Ollama (Free, Local)
# --------------------------------------------
# Install Ollama from: https://ollama.ai
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# --------------------------------------------
# Groq (Free API - Recommended)
# --------------------------------------------
# Get free API key at: https://console.groq.com/
# Sign up with email, no credit card required
GROQ_API_KEY=gsk_your_groq_api_key_here_from_console
GROQ_MODEL=llama-3.3-70b-versatile

# --------------------------------------------
# Hugging Face (Free - Alternative)
# --------------------------------------------
# Get token at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_your_huggingface_token_here

# ============================================
# Security Configuration
# ============================================
# Generate secret key with: openssl rand -hex 32
# IMPORTANT: Change this to a random value in production!
SECRET_KEY=your_secret_key_here_generate_with_openssl_rand_hex_32
ALGORITHM=HS256

# Token expiry in minutes (43200 = 30 days)
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ============================================
# Server Configuration
# ============================================
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO



# INSTRUCTIONS
# ============================================
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual values (MongoDB URL, Groq API key, etc.)
# 3. Generate SECRET_KEY: openssl rand -hex 32
# 4. Never commit .env to version control
# 5. For production, use environment variables or secrets manager